@page "/attendance"
@inject IAttendanceService AttendanceService
@inject IEmployeeService EmployeeService
@inject IAuthenticationService AuthService
@inject NavigationManager Navigation

<PageTitle>Attendance - Philippine Payroll System</PageTitle>

<div class="attendance-page">
    <div class="page-header">
        <h1>Attendance Management</h1>
        <button class="btn btn-primary" @onclick="ShowAddForm">
            <span class="bi bi-plus-circle"></span> Add Attendance
        </button>
    </div>

    <div class="filter-section">
        <div class="filter-row">
            <div class="form-group">
                <label>Start Date:</label>
                <input type="date" class="form-control" @bind="filterStartDate" />
            </div>
            <div class="form-group">
                <label>End Date:</label>
                <input type="date" class="form-control" @bind="filterEndDate" />
            </div>
            <button class="btn btn-secondary" @onclick="FilterByDateRange">Filter</button>
            <button class="btn btn-outline-secondary" @onclick="ClearFilter">Clear</button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="loading">Loading attendance records...</div>
    }
    else
    {
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Employee</th>
                        <th>Time In</th>
                        <th>Time Out</th>
                        <th>Hours Worked</th>
                        <th>Overtime</th>
                        <th>Status</th>
                        <th>Remarks</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var attendance in attendances)
                    {
                        <tr>
                            <td>@attendance.AttendanceDate.ToString("MMM dd, yyyy")</td>
                            <td>@attendance.EmployeeName</td>
                            <td>@attendance.TimeIn?.ToString("hh:mm tt")</td>
                            <td>@attendance.TimeOut?.ToString("hh:mm tt")</td>
                            <td>@attendance.HoursWorked.ToString("N2") hrs</td>
                            <td>@attendance.OvertimeHours.ToString("N2") hrs</td>
                            <td>
                                @if (attendance.IsAbsent)
                                {
                                    <span class="badge badge-danger">Absent</span>
                                }
                                else if (attendance.IsLate)
                                {
                                    <span class="badge badge-warning">Late</span>
                                }
                                else
                                {
                                    <span class="badge badge-success">Present</span>
                                }
                            </td>
                            <td>@attendance.Remarks</td>
                            <td>
                                <button class="btn btn-sm btn-info" @onclick="() => EditAttendance(attendance)">
                                    <span class="bi bi-pencil"></span>
                                </button>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteAttendance(attendance.AttendanceId)">
                                    <span class="bi bi-trash"></span>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (attendances.Count == 0)
            {
                <div class="no-records">No attendance records found.</div>
            }
        </div>
    }
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-dialog" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h3>@(editingAttendance != null ? "Edit" : "Add") Attendance</h3>
                    <button class="close-btn" @onclick="CloseForm">&times;</button>
                </div>
                <div class="modal-body">
                    @if (errorMessage != null)
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }

                    <div class="form-group">
                        <label>Employee *</label>
                        <select class="form-control" @bind="formModel.EmployeeId" disabled="@(editingAttendance != null)">
                            <option value="@Guid.Empty">Select Employee</option>
                            @foreach (var emp in employees)
                            {
                                <option value="@emp.EmployeeId">@emp.FullName (@emp.EmployeeCode)</option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Date *</label>
                        <input type="date" class="form-control" @bind="attendanceDate" />
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Time In</label>
                            <div class="time-input-group">
                                <input type="time" class="form-control" @bind="timeIn" @bind:format="HH:mm" />
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => SetTimeIn(new TimeOnly(8, 0))">8:00 AM</button>
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => SetTimeIn(new TimeOnly(9, 0))">9:00 AM</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="SetTimeInNow">Now</button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Time Out</label>
                            <div class="time-input-group">
                                <input type="time" class="form-control" @bind="timeOut" @bind:format="HH:mm" />
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => SetTimeOut(new TimeOnly(17, 0))">5:00 PM</button>
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => SetTimeOut(new TimeOnly(18, 0))">6:00 PM</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="SetTimeOutNow">Now</button>
                            </div>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Hours Worked</label>
                            <input type="number" step="0.01" class="form-control" @bind="formModel.HoursWorked" />
                        </div>
                        <div class="form-group">
                            <label>Overtime Hours</label>
                            <input type="number" step="0.01" class="form-control" @bind="formModel.OvertimeHours" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>
                            <input type="checkbox" @bind="formModel.IsLate" /> Is Late
                        </label>
                    </div>

                    <div class="form-group">
                        <label>
                            <input type="checkbox" @bind="formModel.IsAbsent" /> Is Absent
                        </label>
                    </div>

                    <div class="form-group">
                        <label>Remarks</label>
                        <textarea class="form-control" rows="3" @bind="formModel.Remarks"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveAttendance" disabled="@isSaving">
                        @(isSaving ? "Saving..." : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .attendance-page {
        padding: 2rem;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .filter-section {
        background: white;
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 1rem;
    }

    .filter-row {
        display: flex;
        gap: 1rem;
        align-items: flex-end;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .time-input-group {
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }

    .time-input-group input {
        flex: 1;
    }

    .time-input-group .btn {
        white-space: nowrap;
        padding: 0.375rem 0.75rem;
        font-size: 0.875rem;
    }

    .table-container {
        background: white;
        border-radius: 8px;
        padding: 1rem;
        overflow-x: auto;
    }

    .badge {
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .badge-success { background: #28a745; color: white; }
    .badge-warning { background: #ffc107; color: #000; }
    .badge-danger { background: #dc3545; color: white; }

    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }

    .modal-dialog {
        background: white;
        border-radius: 8px;
        max-width: 600px;
        width: 100%;
        max-height: 90vh;
        overflow-y: auto;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem;
        border-bottom: 1px solid #e0e0e0;
    }

    .close-btn {
        background: none;
        border: none;
        font-size: 1.5rem;
        cursor: pointer;
        color: #666;
    }

    .modal-body {
        padding: 1rem;
    }

    .modal-footer {
        padding: 1rem;
        border-top: 1px solid #e0e0e0;
        display: flex;
        justify-content: flex-end;
        gap: 0.5rem;
    }

    .form-group {
        margin-bottom: 1rem;
    }

    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 500;
        color: #333;
    }

    .form-control {
        width: 100%;
        padding: 0.5rem;
        border: 1px solid #ddd;
        border-radius: 4px;
    }

    .no-records {
        text-align: center;
        padding: 2rem;
        color: #666;
    }

    .loading {
        text-align: center;
        padding: 2rem;
        color: #666;
    }
</style>

@code {
    private List<AttendanceDto> attendances = new();
    private List<EmployeeListDto> employees = new();
    private AttendanceCreateDto formModel = new();
    private AttendanceDto? editingAttendance;
    private bool showForm = false;
    private bool isLoading = true;
    private bool isSaving = false;
    private string? errorMessage;
    private DateTime? filterStartDate;
    private DateTime? filterEndDate;
    private DateTime attendanceDate = DateTime.Today;
    private TimeOnly? timeIn;
    private TimeOnly? timeOut;

    protected override async Task OnInitializedAsync()
    {
        var isAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (!isAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        attendances = await AttendanceService.GetAllAsync();
        employees = await EmployeeService.GetAllAsync();
        isLoading = false;
    }

    private void ShowAddForm()
    {
        editingAttendance = null;
        formModel = new AttendanceCreateDto 
        { 
            AttendanceDate = DateOnly.FromDateTime(DateTime.Today),
            HoursWorked = 8,
            OvertimeHours = 0
        };
        attendanceDate = DateTime.Today;
        timeIn = null;
        timeOut = null;
        errorMessage = null;
        showForm = true;
    }

    private void EditAttendance(AttendanceDto attendance)
    {
        editingAttendance = attendance;
        formModel = new AttendanceCreateDto
        {
            EmployeeId = attendance.EmployeeId,
            AttendanceDate = attendance.AttendanceDate,
            HoursWorked = attendance.HoursWorked,
            OvertimeHours = attendance.OvertimeHours,
            IsLate = attendance.IsLate,
            IsAbsent = attendance.IsAbsent,
            Remarks = attendance.Remarks
        };
        attendanceDate = attendance.AttendanceDate.ToDateTime(TimeOnly.MinValue);
        timeIn = attendance.TimeIn;
        timeOut = attendance.TimeOut;
        errorMessage = null;
        showForm = true;
    }

    private void CloseForm()
    {
        showForm = false;
        editingAttendance = null;
        errorMessage = null;
    }

    private async Task SaveAttendance()
    {
        if (formModel.EmployeeId == Guid.Empty)
        {
            errorMessage = "Please select an employee";
            return;
        }

        isSaving = true;
        errorMessage = null;

        formModel.AttendanceDate = DateOnly.FromDateTime(attendanceDate);
        formModel.TimeIn = timeIn;
        formModel.TimeOut = timeOut;

        try
        {
            if (editingAttendance != null)
            {
                var updateDto = new AttendanceUpdateDto
                {
                    TimeIn = formModel.TimeIn,
                    TimeOut = formModel.TimeOut,
                    HoursWorked = formModel.HoursWorked,
                    OvertimeHours = formModel.OvertimeHours,
                    IsLate = formModel.IsLate,
                    IsAbsent = formModel.IsAbsent,
                    Remarks = formModel.Remarks
                };
                var success = await AttendanceService.UpdateAsync(editingAttendance.AttendanceId, updateDto);
                if (success)
                {
                    await LoadData();
                    CloseForm();
                }
                else
                {
                    errorMessage = "Failed to update attendance";
                }
            }
            else
            {
                var result = await AttendanceService.CreateAsync(formModel);
                if (result != null)
                {
                    await LoadData();
                    CloseForm();
                }
                else
                {
                    errorMessage = "Failed to create attendance";
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteAttendance(Guid id)
    {
        if (confirm("Are you sure you want to delete this attendance record?"))
        {
            var success = await AttendanceService.DeleteAsync(id);
            if (success)
            {
                await LoadData();
            }
        }
    }

    private async Task FilterByDateRange()
    {
        if (filterStartDate.HasValue && filterEndDate.HasValue)
        {
            isLoading = true;
            attendances = await AttendanceService.GetByDateRangeAsync(
                DateOnly.FromDateTime(filterStartDate.Value),
                DateOnly.FromDateTime(filterEndDate.Value));
            isLoading = false;
        }
    }

    private async Task ClearFilter()
    {
        filterStartDate = null;
        filterEndDate = null;
        await LoadData();
    }

    private void SetTimeIn(TimeOnly time)
    {
        timeIn = time;
    }

    private void SetTimeOut(TimeOnly time)
    {
        timeOut = time;
    }

    private void SetTimeInNow()
    {
        timeIn = TimeOnly.FromDateTime(DateTime.Now);
    }

    private void SetTimeOutNow()
    {
        timeOut = TimeOnly.FromDateTime(DateTime.Now);
    }

    private bool confirm(string message) => true; // Browser confirm() not available in Blazor WASM
}
