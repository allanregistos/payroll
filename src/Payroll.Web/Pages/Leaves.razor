@page "/leaves"
@inject ILeaveService LeaveService
@inject IEmployeeService EmployeeService
@inject IAuthenticationService AuthService
@inject NavigationManager Navigation

<PageTitle>Leave Management - Philippine Payroll System</PageTitle>

<div class="leaves-page">
    <div class="page-header">
        <h1>Leave Management</h1>
        <button class="btn btn-primary" @onclick="ShowAddForm">
            <span class="bi bi-plus-circle"></span> Request Leave
        </button>
    </div>

    @if (isLoading)
    {
        <div class="loading">Loading leave requests...</div>
    }
    else
    {
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Leave Type</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Days</th>
                        <th>Status</th>
                        <th>Requested</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var leave in leaves)
                    {
                        <tr>
                            <td>
                                <div>@leave.EmployeeName</div>
                                <small class="text-muted">@leave.EmployeeNumber</small>
                            </td>
                            <td>@leave.LeaveType</td>
                            <td>@leave.StartDate.ToString("MMM dd, yyyy")</td>
                            <td>@leave.EndDate.ToString("MMM dd, yyyy")</td>
                            <td>@leave.TotalDays days</td>
                            <td>
                                @if (leave.Status == "Approved")
                                {
                                    <span class="badge badge-success">Approved</span>
                                }
                                else if (leave.Status == "Pending")
                                {
                                    <span class="badge badge-warning">Pending</span>
                                }
                                else if (leave.Status == "Rejected")
                                {
                                    <span class="badge badge-danger">Rejected</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">@leave.Status</span>
                                }
                            </td>
                            <td>@leave.RequestedDate.ToString("MMM dd, yyyy")</td>
                            <td>
                                @if (leave.Status == "Pending" && (currentUser?.Role == "Admin" || currentUser?.Role == "HR"))
                                {
                                    <button class="btn btn-sm btn-success" @onclick="() => ApproveLeave(leave.LeaveId)">
                                        <span class="bi bi-check"></span> Approve
                                    </button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => RejectLeave(leave.LeaveId)">
                                        <span class="bi bi-x"></span> Reject
                                    </button>
                                }
                                <button class="btn btn-sm btn-info" @onclick="() => ViewDetails(leave)">
                                    <span class="bi bi-eye"></span>
                                </button>
                                @if (leave.Status == "Pending")
                                {
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteLeave(leave.LeaveId)">
                                        <span class="bi bi-trash"></span>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (leaves.Count == 0)
            {
                <div class="no-records">No leave requests found.</div>
            }
        </div>
    }
</div>

@if (showForm)
{
    <div class="modal-overlay" @onclick="CloseForm">
        <div class="modal-dialog" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h3>Request Leave</h3>
                    <button class="close-btn" @onclick="CloseForm">&times;</button>
                </div>
                <div class="modal-body">
                    @if (errorMessage != null)
                    {
                        <div class="alert alert-danger">@errorMessage</div>
                    }

                    <div class="form-group">
                        <label>Employee *</label>
                        <select class="form-control" @bind="formModel.EmployeeId">
                            <option value="@Guid.Empty">Select Employee</option>
                            @foreach (var emp in employees)
                            {
                                <option value="@emp.EmployeeId">@emp.FullName (@emp.EmployeeCode)</option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Leave Type *</label>
                        <select class="form-control" @bind="formModel.LeaveType">
                            <option value="">Select Type</option>
                            <option value="Sick Leave">Sick Leave</option>
                            <option value="Vacation Leave">Vacation Leave</option>
                            <option value="Emergency Leave">Emergency Leave</option>
                            <option value="Maternity Leave">Maternity Leave</option>
                            <option value="Paternity Leave">Paternity Leave</option>
                            <option value="Unpaid Leave">Unpaid Leave</option>
                        </select>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label>Start Date *</label>
                            <input type="date" class="form-control" @bind="startDate" />
                        </div>
                        <div class="form-group">
                            <label>End Date *</label>
                            <input type="date" class="form-control" @bind="endDate" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Total Days</label>
                        <input type="number" step="0.5" class="form-control" @bind="formModel.TotalDays" />
                    </div>

                    <div class="form-group">
                        <label>Reason *</label>
                        <textarea class="form-control" rows="4" @bind="formModel.Reason"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveLeave" disabled="@isSaving">
                        @(isSaving ? "Saving..." : "Submit Request")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (selectedLeave != null)
{
    <div class="modal-overlay" @onclick="CloseDetails">
        <div class="modal-dialog" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header">
                    <h3>Leave Request Details</h3>
                    <button class="close-btn" @onclick="CloseDetails">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="details-section">
                        <div class="details-row">
                            <span class="label">Employee:</span>
                            <span class="value">@selectedLeave.EmployeeName (@selectedLeave.EmployeeNumber)</span>
                        </div>
                        <div class="details-row">
                            <span class="label">Leave Type:</span>
                            <span class="value">@selectedLeave.LeaveType</span>
                        </div>
                        <div class="details-row">
                            <span class="label">Period:</span>
                            <span class="value">@selectedLeave.StartDate.ToString("MMM dd, yyyy") - @selectedLeave.EndDate.ToString("MMM dd, yyyy")</span>
                        </div>
                        <div class="details-row">
                            <span class="label">Total Days:</span>
                            <span class="value">@selectedLeave.TotalDays days</span>
                        </div>
                        <div class="details-row">
                            <span class="label">Status:</span>
                            <span class="value">
                                @if (selectedLeave.Status == "Approved")
                                {
                                    <span class="badge badge-success">Approved</span>
                                }
                                else if (selectedLeave.Status == "Pending")
                                {
                                    <span class="badge badge-warning">Pending</span>
                                }
                                else if (selectedLeave.Status == "Rejected")
                                {
                                    <span class="badge badge-danger">Rejected</span>
                                }
                            </span>
                        </div>
                        <div class="details-row">
                            <span class="label">Requested On:</span>
                            <span class="value">@selectedLeave.RequestedDate.ToString("MMM dd, yyyy hh:mm tt")</span>
                        </div>
                        @if (selectedLeave.ApprovedDate.HasValue)
                        {
                            <div class="details-row">
                                <span class="label">Approved On:</span>
                                <span class="value">@selectedLeave.ApprovedDate.Value.ToString("MMM dd, yyyy hh:mm tt")</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(selectedLeave.ApproverName))
                        {
                            <div class="details-row">
                                <span class="label">Approved By:</span>
                                <span class="value">@selectedLeave.ApproverName</span>
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(selectedLeave.Reason))
                    {
                        <div class="details-section">
                            <h5>Reason</h5>
                            <p>@selectedLeave.Reason</p>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(selectedLeave.Remarks))
                    {
                        <div class="details-section">
                            <h5>Remarks</h5>
                            <p>@selectedLeave.Remarks</p>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseDetails">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .leaves-page {
        padding: 2rem;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

    .table-container {
        background: white;
        border-radius: 8px;
        padding: 1rem;
        overflow-x: auto;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .details-section {
        margin-bottom: 1.5rem;
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 4px;
    }

    .details-section h5 {
        margin-bottom: 0.5rem;
        color: #333;
    }

    .details-row {
        display: flex;
        justify-content: space-between;
        padding: 0.5rem 0;
        border-bottom: 1px solid #e0e0e0;
    }

    .details-row:last-child {
        border-bottom: none;
    }

    .details-row .label {
        color: #666;
        font-weight: 500;
    }

    .details-row .value {
        color: #333;
    }

    .badge {
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .badge-success { background: #28a745; color: white; }
    .badge-warning { background: #ffc107; color: #000; }
    .badge-danger { background: #dc3545; color: white; }
    .badge-secondary { background: #6c757d; color: white; }

    .text-muted {
        color: #6c757d;
        font-size: 0.875rem;
    }

    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 1000;
    }

    .modal-dialog {
        background: white;
        border-radius: 8px;
        max-width: 600px;
        width: 100%;
        max-height: 90vh;
        overflow-y: auto;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem;
        border-bottom: 1px solid #e0e0e0;
    }

    .close-btn {
        background: none;
        border: none;
        font-size: 1.5rem;
        cursor: pointer;
        color: #666;
    }

    .modal-body {
        padding: 1rem;
    }

    .modal-footer {
        padding: 1rem;
        border-top: 1px solid #e0e0e0;
        display: flex;
        justify-content: flex-end;
        gap: 0.5rem;
    }

    .form-group {
        margin-bottom: 1rem;
    }

    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 500;
        color: #333;
    }

    .form-control {
        width: 100%;
        padding: 0.5rem;
        border: 1px solid #ddd;
        border-radius: 4px;
    }

    .no-records {
        text-align: center;
        padding: 2rem;
        color: #666;
    }

    .loading {
        text-align: center;
        padding: 2rem;
        color: #666;
    }
</style>

@code {
    private List<LeaveDto> leaves = new();
    private List<EmployeeListDto> employees = new();
    private LeaveCreateDto formModel = new();
    private LeaveDto? selectedLeave;
    private UserResponse? currentUser;
    private bool showForm = false;
    private bool isLoading = true;
    private bool isSaving = false;
    private string? errorMessage;
    private DateTime startDate = DateTime.Today;
    private DateTime endDate = DateTime.Today.AddDays(1);

    protected override async Task OnInitializedAsync()
    {
        var isAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (!isAuthenticated)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        currentUser = await AuthService.GetCurrentUserAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        leaves = await LeaveService.GetAllAsync();
        employees = await EmployeeService.GetAllAsync();
        isLoading = false;
    }

    private void ShowAddForm()
    {
        formModel = new LeaveCreateDto
        {
            StartDate = DateOnly.FromDateTime(startDate),
            EndDate = DateOnly.FromDateTime(endDate),
            TotalDays = 1
        };
        errorMessage = null;
        showForm = true;
    }

    private void CloseForm()
    {
        showForm = false;
        errorMessage = null;
    }

    private async Task SaveLeave()
    {
        if (formModel.EmployeeId == Guid.Empty)
        {
            errorMessage = "Please select an employee";
            return;
        }

        if (string.IsNullOrEmpty(formModel.LeaveType))
        {
            errorMessage = "Please select a leave type";
            return;
        }

        if (string.IsNullOrEmpty(formModel.Reason))
        {
            errorMessage = "Please provide a reason";
            return;
        }

        isSaving = true;
        errorMessage = null;

        formModel.StartDate = DateOnly.FromDateTime(startDate);
        formModel.EndDate = DateOnly.FromDateTime(endDate);

        try
        {
            var result = await LeaveService.CreateAsync(formModel);
            if (result != null)
            {
                await LoadData();
                CloseForm();
            }
            else
            {
                errorMessage = "Failed to create leave request";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ViewDetails(LeaveDto leave)
    {
        selectedLeave = leave;
    }

    private void CloseDetails()
    {
        selectedLeave = null;
    }

    private async Task ApproveLeave(Guid id)
    {
        var updateDto = new LeaveUpdateDto
        {
            Status = "Approved",
            Remarks = "Approved by " + currentUser?.FirstName
        };
        var success = await LeaveService.UpdateAsync(id, updateDto);
        if (success)
        {
            await LoadData();
        }
    }

    private async Task RejectLeave(Guid id)
    {
        var updateDto = new LeaveUpdateDto
        {
            Status = "Rejected",
            Remarks = "Rejected by " + currentUser?.FirstName
        };
        var success = await LeaveService.UpdateAsync(id, updateDto);
        if (success)
        {
            await LoadData();
        }
    }

    private async Task DeleteLeave(Guid id)
    {
        var success = await LeaveService.DeleteAsync(id);
        if (success)
        {
            await LoadData();
        }
    }
}
