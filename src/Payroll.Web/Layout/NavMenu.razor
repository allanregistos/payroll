@inject IAuthenticationService AuthService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Steniel Payroll</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>
        
        @if (currentUser?.Role == "Admin" || currentUser?.Role == "HR")
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="employees">
                    <span class="bi bi-people-fill-nav-menu" aria-hidden="true"></span> Employees
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="compensation">
                    <span class="bi bi-currency-exchange-nav-menu" aria-hidden="true"></span> Compensation
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="attendance">
                    <span class="bi bi-calendar-check-fill-nav-menu" aria-hidden="true"></span> Attendance
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="payroll">
                    <span class="bi bi-cash-stack-nav-menu" aria-hidden="true"></span> Payroll
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="payroll-periods">
                    <span class="bi bi-calendar-range-nav-menu" aria-hidden="true"></span> Pay Periods
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="government-contributions">
                    <span class="bi bi-building-nav-menu" aria-hidden="true"></span> Gov't Contributions
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="employee-loans">
                    <span class="bi bi-cash-coin-nav-menu" aria-hidden="true"></span> Loans
                </NavLink>
            </div>
        }
        
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="leaves">
                <span class="bi bi-calendar-event-nav-menu" aria-hidden="true"></span> Leaves
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private UserResponse? currentUser;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override async Task OnInitializedAsync()
    {
        currentUser = await AuthService.GetCurrentUserAsync();
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
